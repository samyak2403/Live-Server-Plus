{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/src/**/*.js"
      ],
      "preLaunchTask": "npm: install",
      "env": {
        "Live Server Pro_DEBUG": "true"
      }
    }
  ]
}
